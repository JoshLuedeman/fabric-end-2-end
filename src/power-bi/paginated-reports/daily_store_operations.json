{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/report/1.0.0/schema.json",
  "name": "Daily Store Operations Report",
  "description": "Pixel-perfect paginated report for per-store daily operations summary. Designed for print/PDF distribution to store managers each morning. Includes sales totals, transaction counts, top products, staffing hours, and inventory alerts.",
  "report_type": "paginated",
  "format": "PBIR-Legacy",
  "datasetBinding": {
    "datasetReference": {
      "byPath": {
        "path": "../../semantic-models/contoso_operations.bim"
      }
    }
  },
  "parameters": [
    {
      "name": "StoreID",
      "type": "integer",
      "prompt": "Select Store",
      "allow_multiple": false,
      "available_values_query": "SELECT DISTINCT StoreID, StoreName FROM DimStore WHERE IsActive = 1 ORDER BY StoreName",
      "default_value": null,
      "required": true
    },
    {
      "name": "ReportDate",
      "type": "date",
      "prompt": "Report Date",
      "allow_multiple": false,
      "default_value": "=Today()-1",
      "required": true
    }
  ],
  "page_layout": {
    "page_size": "Letter",
    "orientation": "Portrait",
    "margins": {
      "top": "0.5in",
      "bottom": "0.5in",
      "left": "0.75in",
      "right": "0.75in"
    }
  },
  "report_sections": [
    {
      "name": "Header",
      "type": "page_header",
      "height": "1.2in",
      "items": [
        {
          "type": "image",
          "description": "Contoso logo",
          "position": { "left": "0in", "top": "0in", "width": "2in", "height": "0.8in" }
        },
        {
          "type": "textbox",
          "value": "='Daily Operations Report — ' & Parameters!ReportDate.Value",
          "position": { "left": "2.5in", "top": "0.1in", "width": "4.5in", "height": "0.4in" },
          "style": { "font_size": "16pt", "font_weight": "bold", "color": "#1A1A2E" }
        },
        {
          "type": "textbox",
          "value": "=First(Fields!StoreName.Value)",
          "position": { "left": "2.5in", "top": "0.5in", "width": "4.5in", "height": "0.3in" },
          "style": { "font_size": "12pt", "color": "#4A4A4A" }
        }
      ]
    },
    {
      "name": "DailySummaryKPIs",
      "type": "body",
      "height": "1.5in",
      "description": "Key metrics row: Total Revenue, Transaction Count, Avg Transaction Value, Customers Served, Return Rate",
      "items": [
        {
          "type": "kpi_card",
          "label": "Total Revenue",
          "expression": "=Sum(Fields!SalesAmount.Value)",
          "format": "$#,##0",
          "position": { "left": "0in", "top": "0in", "width": "1.4in", "height": "1.2in" }
        },
        {
          "type": "kpi_card",
          "label": "Transactions",
          "expression": "=CountDistinct(Fields!TransactionID.Value)",
          "format": "#,##0",
          "position": { "left": "1.5in", "top": "0in", "width": "1.4in", "height": "1.2in" }
        },
        {
          "type": "kpi_card",
          "label": "Avg Transaction",
          "expression": "=Sum(Fields!SalesAmount.Value) / CountDistinct(Fields!TransactionID.Value)",
          "format": "$#,##0.00",
          "position": { "left": "3.0in", "top": "0in", "width": "1.4in", "height": "1.2in" }
        },
        {
          "type": "kpi_card",
          "label": "Customers",
          "expression": "=CountDistinct(Fields!CustomerID.Value)",
          "format": "#,##0",
          "position": { "left": "4.5in", "top": "0in", "width": "1.4in", "height": "1.2in" }
        },
        {
          "type": "kpi_card",
          "label": "Return Rate",
          "expression": "=Sum(IIf(Fields!IsReturn.Value = True, 1, 0)) / Count(Fields!TransactionID.Value)",
          "format": "0.0%",
          "position": { "left": "6.0in", "top": "0in", "width": "1.4in", "height": "1.2in" }
        }
      ]
    },
    {
      "name": "HourlySalesBreakdown",
      "type": "body",
      "height": "2.5in",
      "description": "Bar chart showing sales by hour of day with transaction count overlay",
      "items": [
        {
          "type": "chart",
          "chart_type": "column",
          "category": "Fields!HourOfDay.Value",
          "values": ["Sum(Fields!SalesAmount.Value)"],
          "secondary_values": ["CountDistinct(Fields!TransactionID.Value)"],
          "position": { "left": "0in", "top": "0in", "width": "7.5in", "height": "2.3in" },
          "title": "Sales by Hour of Day"
        }
      ]
    },
    {
      "name": "TopProductsTable",
      "type": "body",
      "height": "3.0in",
      "description": "Table of top 20 products by revenue for the selected store and date",
      "items": [
        {
          "type": "table",
          "title": "Top 20 Products by Revenue",
          "columns": [
            { "field": "Fields!ProductName.Value", "header": "Product", "width": "2.5in" },
            { "field": "Fields!CategoryName.Value", "header": "Category", "width": "1.2in" },
            { "field": "Sum(Fields!Quantity.Value)", "header": "Qty Sold", "width": "0.8in", "format": "#,##0" },
            { "field": "Sum(Fields!SalesAmount.Value)", "header": "Revenue", "width": "1.0in", "format": "$#,##0" },
            { "field": "Sum(Fields!Margin.Value)", "header": "Margin", "width": "1.0in", "format": "$#,##0" },
            { "field": "Sum(Fields!Margin.Value)/Sum(Fields!SalesAmount.Value)", "header": "Margin %", "width": "0.8in", "format": "0.0%" }
          ],
          "sorting": { "field": "Sum(Fields!SalesAmount.Value)", "direction": "descending" },
          "top_n": 20,
          "position": { "left": "0in", "top": "0in", "width": "7.5in", "height": "2.8in" }
        }
      ]
    },
    {
      "name": "InventoryAlerts",
      "type": "body",
      "height": "2.0in",
      "description": "Table of items at or below reorder point requiring attention",
      "items": [
        {
          "type": "table",
          "title": "Inventory Alerts — Items Below Reorder Point",
          "columns": [
            { "field": "Fields!ProductName.Value", "header": "Product", "width": "2.0in" },
            { "field": "Fields!OnHandQty.Value", "header": "On Hand", "width": "0.8in", "format": "#,##0" },
            { "field": "Fields!ReorderPoint.Value", "header": "Reorder Pt", "width": "0.8in", "format": "#,##0" },
            { "field": "Fields!AvgDailySales.Value", "header": "Avg Daily Sales", "width": "1.0in", "format": "#,##0.0" },
            { "field": "Fields!DaysOfSupply.Value", "header": "Days Supply", "width": "0.8in", "format": "#,##0" },
            { "field": "Fields!SupplierName.Value", "header": "Supplier", "width": "1.8in" }
          ],
          "filter": "Fields!OnHandQty.Value <= Fields!ReorderPoint.Value",
          "sorting": { "field": "Fields!DaysOfSupply.Value", "direction": "ascending" },
          "position": { "left": "0in", "top": "0in", "width": "7.5in", "height": "1.8in" },
          "conditional_formatting": {
            "field": "Fields!DaysOfSupply.Value",
            "rules": [
              { "condition": "<= 3", "background_color": "#FDE7E9", "font_color": "#D13438" },
              { "condition": "<= 7", "background_color": "#FFF4CE", "font_color": "#8A6914" }
            ]
          }
        }
      ]
    },
    {
      "name": "Footer",
      "type": "page_footer",
      "height": "0.5in",
      "items": [
        {
          "type": "textbox",
          "value": "='Generated: ' & Now() & ' | Contoso Global Retail — Confidential'",
          "position": { "left": "0in", "top": "0in", "width": "5in", "height": "0.3in" },
          "style": { "font_size": "8pt", "color": "#888888" }
        },
        {
          "type": "textbox",
          "value": "='Page ' & Globals!PageNumber & ' of ' & Globals!TotalPages",
          "position": { "left": "6in", "top": "0in", "width": "1.5in", "height": "0.3in" },
          "style": { "font_size": "8pt", "color": "#888888", "text_align": "right" }
        }
      ]
    }
  ],
  "subscriptions": {
    "schedule": "daily at 06:00 local store time",
    "recipients": "store_manager@{store_domain}",
    "format": "PDF",
    "subject": "Daily Operations Report — {StoreName} — {ReportDate}"
  }
}
