{
    "name": "pl_data_quality",
    "properties": {
        "description": "Data quality validation pipeline — runs row count validation, freshness checks, null rate checks, and cross-table referential integrity. Outputs a quality report to the gold layer dq_validation_results table.",
        "activities": [
            {
                "name": "DQ Row Count Validation",
                "type": "TridentNotebook",
                "dependsOn": [],
                "policy": {
                    "timeout": "0.01:00:00",
                    "retry": 1,
                    "retryIntervalInSeconds": 60
                },
                "typeProperties": {
                    "notebookId": "dq_row_count_validation",
                    "workspaceId": {
                        "value": "@pipeline().parameters.workspace_id",
                        "type": "Expression"
                    },
                    "parameters": {
                        "run_id": {
                            "value": "@pipeline().RunId",
                            "type": "Expression"
                        }
                    }
                }
            },
            {
                "name": "DQ Freshness Check",
                "type": "TridentNotebook",
                "dependsOn": [],
                "policy": {
                    "timeout": "0.01:00:00",
                    "retry": 1,
                    "retryIntervalInSeconds": 60
                },
                "typeProperties": {
                    "notebookId": "dq_freshness_check",
                    "workspaceId": {
                        "value": "@pipeline().parameters.workspace_id",
                        "type": "Expression"
                    },
                    "parameters": {
                        "run_id": {
                            "value": "@pipeline().RunId",
                            "type": "Expression"
                        },
                        "sla_hours": {
                            "value": "@pipeline().parameters.sla_hours",
                            "type": "Expression"
                        }
                    }
                }
            },
            {
                "name": "DQ Null Rate Check",
                "type": "TridentNotebook",
                "dependsOn": [],
                "policy": {
                    "timeout": "0.01:00:00",
                    "retry": 1,
                    "retryIntervalInSeconds": 60
                },
                "typeProperties": {
                    "notebookId": "dq_null_rate_check",
                    "workspaceId": {
                        "value": "@pipeline().parameters.workspace_id",
                        "type": "Expression"
                    },
                    "parameters": {
                        "run_id": {
                            "value": "@pipeline().RunId",
                            "type": "Expression"
                        }
                    }
                }
            },
            {
                "name": "DQ Referential Integrity",
                "type": "TridentNotebook",
                "dependsOn": [],
                "policy": {
                    "timeout": "0.01:00:00",
                    "retry": 1,
                    "retryIntervalInSeconds": 60
                },
                "typeProperties": {
                    "notebookId": "dq_referential_integrity",
                    "workspaceId": {
                        "value": "@pipeline().parameters.workspace_id",
                        "type": "Expression"
                    },
                    "parameters": {
                        "run_id": {
                            "value": "@pipeline().RunId",
                            "type": "Expression"
                        }
                    }
                }
            },
            {
                "name": "Consolidate DQ Results",
                "type": "TridentNotebook",
                "dependsOn": [
                    {
                        "activity": "DQ Row Count Validation",
                        "dependencyConditions": [
                            "Completed"
                        ]
                    },
                    {
                        "activity": "DQ Freshness Check",
                        "dependencyConditions": [
                            "Completed"
                        ]
                    },
                    {
                        "activity": "DQ Null Rate Check",
                        "dependencyConditions": [
                            "Completed"
                        ]
                    },
                    {
                        "activity": "DQ Referential Integrity",
                        "dependencyConditions": [
                            "Completed"
                        ]
                    }
                ],
                "policy": {
                    "timeout": "0.00:30:00",
                    "retry": 1,
                    "retryIntervalInSeconds": 60
                },
                "typeProperties": {
                    "notebookId": "dq_consolidate_results",
                    "workspaceId": {
                        "value": "@pipeline().parameters.workspace_id",
                        "type": "Expression"
                    },
                    "parameters": {
                        "run_id": {
                            "value": "@pipeline().RunId",
                            "type": "Expression"
                        },
                        "output_table": {
                            "value": "dq_validation_results",
                            "type": "Expression"
                        }
                    }
                }
            }
        ],
        "parameters": {
            "workspace_id": {
                "type": "string",
                "defaultValue": ""
            },
            "sla_hours": {
                "type": "int",
                "defaultValue": 24
            }
        },
        "annotations": [
            "data-quality",
            "validation",
            "gold",
            "monitoring"
        ]
    }
}
