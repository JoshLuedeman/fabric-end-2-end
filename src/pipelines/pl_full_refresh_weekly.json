{
    "name": "pl_full_refresh_weekly",
    "properties": {
        "description": "Weekly full refresh pipeline — re-ingests all file-based sources (overwrites bronze), then runs the full silver → gold → warehouse chain. Used for data quality reconciliation and ensuring bronze/silver/gold consistency.",
        "activities": [
            {
                "name": "Full Ingest Dimensions",
                "type": "TridentNotebook",
                "dependsOn": [],
                "policy": {
                    "timeout": "0.02:00:00",
                    "retry": 2,
                    "retryIntervalInSeconds": 60
                },
                "typeProperties": {
                    "notebookId": "ingest_dimensions",
                    "workspaceId": {
                        "value": "@pipeline().parameters.workspace_id",
                        "type": "Expression"
                    },
                    "parameters": {
                        "load_date": {
                            "value": "@utcNow('yyyy-MM-dd')",
                            "type": "Expression"
                        }
                    }
                }
            },
            {
                "name": "Full Ingest Sales",
                "type": "TridentNotebook",
                "dependsOn": [],
                "policy": {
                    "timeout": "0.02:00:00",
                    "retry": 2,
                    "retryIntervalInSeconds": 60
                },
                "typeProperties": {
                    "notebookId": "ingest_sales_transactions",
                    "workspaceId": {
                        "value": "@pipeline().parameters.workspace_id",
                        "type": "Expression"
                    },
                    "parameters": {
                        "load_date": {
                            "value": "@utcNow('yyyy-MM-dd')",
                            "type": "Expression"
                        }
                    }
                }
            },
            {
                "name": "Full Ingest Inventory",
                "type": "TridentNotebook",
                "dependsOn": [],
                "policy": {
                    "timeout": "0.02:00:00",
                    "retry": 2,
                    "retryIntervalInSeconds": 60
                },
                "typeProperties": {
                    "notebookId": "ingest_inventory_snapshots",
                    "workspaceId": {
                        "value": "@pipeline().parameters.workspace_id",
                        "type": "Expression"
                    },
                    "parameters": {
                        "load_date": {
                            "value": "@utcNow('yyyy-MM-dd')",
                            "type": "Expression"
                        }
                    }
                }
            },
            {
                "name": "Full Ingest from OLTP",
                "type": "TridentNotebook",
                "dependsOn": [],
                "policy": {
                    "timeout": "0.02:00:00",
                    "retry": 2,
                    "retryIntervalInSeconds": 60
                },
                "typeProperties": {
                    "notebookId": "ingest_from_sqldb",
                    "workspaceId": {
                        "value": "@pipeline().parameters.workspace_id",
                        "type": "Expression"
                    }
                }
            },
            {
                "name": "Run Medallion Transforms",
                "type": "ExecutePipeline",
                "dependsOn": [
                    {
                        "activity": "Full Ingest Dimensions",
                        "dependencyConditions": [
                            "Succeeded"
                        ]
                    },
                    {
                        "activity": "Full Ingest Sales",
                        "dependencyConditions": [
                            "Succeeded"
                        ]
                    },
                    {
                        "activity": "Full Ingest Inventory",
                        "dependencyConditions": [
                            "Succeeded"
                        ]
                    },
                    {
                        "activity": "Full Ingest from OLTP",
                        "dependencyConditions": [
                            "Succeeded"
                        ]
                    }
                ],
                "policy": {
                    "timeout": "0.04:00:00",
                    "retry": 1,
                    "retryIntervalInSeconds": 120
                },
                "typeProperties": {
                    "pipeline": {
                        "referenceName": "pl_transform_medallion",
                        "type": "PipelineReference"
                    },
                    "parameters": {
                        "workspace_id": {
                            "value": "@pipeline().parameters.workspace_id",
                            "type": "Expression"
                        }
                    },
                    "waitOnCompletion": true
                }
            },
            {
                "name": "Load Warehouse Full Refresh",
                "type": "ExecutePipeline",
                "dependsOn": [
                    {
                        "activity": "Run Medallion Transforms",
                        "dependencyConditions": [
                            "Succeeded"
                        ]
                    }
                ],
                "policy": {
                    "timeout": "0.04:00:00",
                    "retry": 1,
                    "retryIntervalInSeconds": 120
                },
                "typeProperties": {
                    "pipeline": {
                        "referenceName": "pl_load_warehouse",
                        "type": "PipelineReference"
                    },
                    "parameters": {
                        "warehouse_connection_id": {
                            "value": "@pipeline().parameters.warehouse_connection_id",
                            "type": "Expression"
                        },
                        "load_date": {
                            "value": "@utcNow('yyyy-MM-dd')",
                            "type": "Expression"
                        },
                        "full_refresh": {
                            "value": "@pipeline().parameters.force_full_refresh",
                            "type": "Expression"
                        }
                    },
                    "waitOnCompletion": true
                }
            }
        ],
        "parameters": {
            "workspace_id": {
                "type": "string",
                "defaultValue": ""
            },
            "force_full_refresh": {
                "type": "bool",
                "defaultValue": true
            },
            "warehouse_connection_id": {
                "type": "string",
                "defaultValue": ""
            }
        },
        "annotations": [
            "bronze",
            "silver",
            "gold",
            "warehouse",
            "full-refresh",
            "weekly",
            "reconciliation"
        ]
    }
}
