{
  "$schema": "https://learn.microsoft.com/azure/cosmos-db/nosql/schema",
  "_comment": "Contoso Global Retail — Product Catalog (Cosmos DB NoSQL)",
  "containerConfig": {
    "containerName": "product_catalog",
    "partitionKey": {
      "paths": ["/category/l1"],
      "kind": "Hash",
      "version": 2
    },
    "indexingPolicy": {
      "automatic": true,
      "indexingMode": "consistent",
      "includedPaths": [
        { "path": "/category/*" },
        { "path": "/pricing/list_price/?" },
        { "path": "/pricing/sale_price/?" },
        { "path": "/reviews_summary/avg_rating/?" },
        { "path": "/tags/[]" }
      ],
      "excludedPaths": [
        { "path": "/images/*" },
        { "path": "/seo_metadata/*" }
      ],
      "compositeIndexes": [
        [
          { "path": "/category/l1", "order": "ascending" },
          { "path": "/pricing/list_price", "order": "descending" }
        ],
        [
          { "path": "/category/l1", "order": "ascending" },
          { "path": "/reviews_summary/avg_rating", "order": "descending" }
        ]
      ]
    },
    "uniqueKeyPolicy": {
      "uniqueKeys": [
        { "paths": ["/product_id"] }
      ]
    },
    "defaultTtl": -1
  },
