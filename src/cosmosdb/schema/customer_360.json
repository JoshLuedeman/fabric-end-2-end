{
  "$schema": "https://learn.microsoft.com/azure/cosmos-db/nosql/schema",
  "_comment": "Tales & Timber — Customer 360 Profile (Cosmos DB NoSQL)",
  "containerConfig": {
    "containerName": "customer_360",
    "partitionKey": {
      "paths": ["/loyalty_tier"],
      "kind": "Hash",
      "version": 2
    },
    "indexingPolicy": {
      "automatic": true,
      "indexingMode": "consistent",
      "includedPaths": [
        { "path": "/customer_id/?" },
        { "path": "/loyalty_tier/?" },
        { "path": "/lifetime_value/?" },
        { "path": "/churn_risk_score/?" },
        { "path": "/segments/[]" },
        { "path": "/demographics/zip_code/?" },
        { "path": "/preferred_store/?" }
      ],
      "excludedPaths": [
        { "path": "/communication_preferences/*" }
      ],
      "compositeIndexes": [
        [
          { "path": "/loyalty_tier", "order": "ascending" },
          { "path": "/lifetime_value", "order": "descending" }
        ],
        [
          { "path": "/loyalty_tier", "order": "ascending" },
          { "path": "/churn_risk_score", "order": "descending" }
        ]
      ]
    },
    "uniqueKeyPolicy": {
      "uniqueKeys": [
        { "paths": ["/customer_id"] }
      ]
    },
    "defaultTtl": -1
  },
