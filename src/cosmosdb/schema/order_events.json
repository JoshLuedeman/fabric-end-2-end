{
  "$schema": "https://learn.microsoft.com/azure/cosmos-db/nosql/schema",
  "_comment": "Contoso Global Retail — Order Events / Event Sourcing (Cosmos DB NoSQL)",
  "containerConfig": {
    "containerName": "order_events",
    "partitionKey": {
      "paths": ["/order_id"],
      "kind": "Hash",
      "version": 2
    },
    "indexingPolicy": {
      "automatic": true,
      "indexingMode": "consistent",
      "includedPaths": [
        { "path": "/order_id/?" },
        { "path": "/event_type/?" },
        { "path": "/timestamp/?" },
        { "path": "/store_id/?" },
        { "path": "/customer_id/?" }
      ],
      "excludedPaths": [
        { "path": "/items/*" },
        { "path": "/status_metadata/*" }
      ],
      "compositeIndexes": [
        [
          { "path": "/order_id", "order": "ascending" },
          { "path": "/timestamp", "order": "ascending" }
        ]
      ]
    },
    "uniqueKeyPolicy": {
      "uniqueKeys": [
        { "paths": ["/event_id"] }
      ]
    },
    "defaultTtl": 7776000,
    "_ttl_comment": "90 days — events older than 90 days are archived to Lakehouse via mirroring"
  },
  "sampleDocuments_comment": "Complete lifecycle of order ORD-2025-091003: placed → confirmed → picking → packed → shipped → delivered",
